{
    "name": "signal-hub",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "start": "tsx src/index.ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "rsi-check": "tsx scripts/rsi_check.ts",
        "compare": "tsx scripts/compare_output.ts",
        "compare:live": "tsx scripts/compare_output.ts --live",
        "rsi-debug": "tsx scripts/rsi_debug.ts"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    }
}
